{
  "memory_palace": {
    "description": "记忆宫殿模块",
    "type": "bool",
    "default": true,
    "hint": "启用或禁用记忆宫殿模块",
    "editable": true,
    "display_name": "记忆宫殿"
  },
  "working_memory_limit": {
    "description": "工作记忆条数上限",
    "type": "int",
    "default": 6,
    "hint": "每次自动注入的最大记忆条数。内存紧张时建议3-4",
    "editable": true,
    "display_name": "工作记忆条数"
  },
  "working_memory_max_chars": {
    "description": "工作记忆总字符上限",
    "type": "int",
    "default": 800,
    "hint": "自动注入的记忆总字符数上限。内存紧张时建议400-600",
    "editable": true,
    "display_name": "工作记忆字符上限"
  },
  "memory_cleanup_enabled": {
    "description": "启用记忆清理",
    "type": "bool",
    "default": true,
    "editable": true,
    "display_name": "启用清理"
  },
  "memory_cleanup_days": {
    "description": "清理多少天前的记忆",
    "type": "int",
    "default": 365,
    "hint": "0=永不按时间清理",
    "editable": true,
    "display_name": "清理天数"
  },
  "memory_cleanup_max": {
    "description": "最大记忆数量",
    "type": "int",
    "default": 10000,
    "hint": "0=永不按数量清理",
    "editable": true,
    "display_name": "最大数量"
  },
  "search_max_results": {
    "description": "最大搜索结果数",
    "type": "int",
    "default": 50,
    "editable": true,
    "display_name": "最大结果数"
  },
  "backup_interval": {
    "description": "自动备份间隔（小时）",
    "type": "int",
    "default": 24,
    "editable": true,
    "display_name": "备份间隔"
  },
  "backup_max_count": {
    "description": "备份最大数量",
    "type": "int",
    "default": 10,
    "hint": "超过后自动清理旧备份",
    "editable": true,
    "display_name": "备份最大数量"
  },
  "webui_host": {
    "description": "WebUI监听地址",
    "type": "string",
    "default": "0.0.0.0",
    "hint": "0.0.0.0=允许外网访问(推荐Docker/云服务器) | 127.0.0.1=仅本机访问(更安全)",
    "editable": true,
    "display_name": "监听地址"
  },
  "webui_port": {
    "description": "WebUI服务端口",
    "type": "int",
    "default": 5000,
    "hint": "修改后需重启插件生效",
    "editable": true,
    "display_name": "监听端口"
  },
  "context_inject_position": {
    "description": "上下文注入位置",
    "type": "string",
    "default": "system_prompt",
    "options": ["system_prompt", "user_prompt", "insert_system_prompt"],
    "hint": "system_prompt=系统提示词, user_prompt=用户消息前, insert_system_prompt=插入独立系统消息",
    "editable": true,
    "display_name": "注入位置"
  },
  "relation_injection_refresh_time": {
    "description": "关系注入刷新时间(秒)",
    "type": "int",
    "default": 3600,
    "hint": "-1=每次都注入",
    "editable": true,
    "display_name": "注入刷新时间"
  },
  "category_model": {
    "description": "分类判断模型",
    "type": "string",
    "default": "",
    "_special": "select_provider",
    "hint": "留空则使用默认模型",
    "editable": true,
    "display_name": "分类模型"
  },
  "cache_ttl": {
    "description": "缓存过期时间(秒)",
    "type": "int",
    "default": 300,
    "hint": "0=禁用缓存。内存紧张建议60-120",
    "editable": true,
    "display_name": "缓存TTL"
  },
  "max_cache_size": {
    "description": "最大缓存条目",
    "type": "int",
    "default": 200,
    "hint": "内存紧张建议50-100",
    "editable": true,
    "display_name": "缓存上限"
  },
  "mmr_enabled": {
    "description": "MMR多样性筛选",
    "type": "bool",
    "default": true,
    "editable": true,
    "display_name": "MMR筛选"
  },
  "mmr_lambda": {
    "description": "MMR平衡参数",
    "type": "float",
    "default": 0.7,
    "hint": "越大越重相关性，越小越重多样性",
    "editable": true,
    "display_name": "MMR参数"
  },
  "identity_mapping_enabled": {
    "description": "身份映射系统",
    "type": "bool",
    "default": true,
    "editable": true,
    "display_name": "身份映射"
  },
  "memory_categories": {
    "description": "记忆分类列表",
    "type": "list",
    "default": ["技术笔记", "生活记录", "学习资料", "个人想法"],
    "editable": true,
    "display_name": "记忆分类"
  },
  "max_aliases_per_user": {
    "description": "每用户最大别名数",
    "type": "int",
    "default": 3,
    "editable": true,
    "display_name": "最大别名数"
  },
  "max_extracted_tags": {
    "description": "每条记忆最大标签数",
    "type": "int",
    "default": 6,
    "hint": "标签越多搜索越准但占空间",
    "editable": true,
    "display_name": "最大标签数"
  }
}
